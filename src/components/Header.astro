---
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="sticky top-0 z-10 bg-[var(--color-bg)]/80 backdrop-blur border-b border-[var(--color-border)]">
  <nav class="max-w-3xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <a href="/" class="text-lg font-bold hover:text-[var(--color-primary)] transition-colors">
      Fang's Blog
    </a>
    <div class="flex items-center gap-4 sm:gap-6 text-sm">
      <a href="/" class="hover:text-[var(--color-primary)] transition-colors">Home</a>
      <a href="/about" class="hover:text-[var(--color-primary)] transition-colors">About</a>
      <ThemeToggle />
    </div>
  </nav>
</header>
