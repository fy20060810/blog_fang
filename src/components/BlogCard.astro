---
interface Props {
  title: string;
  description?: string;
  date: string;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags } = Astro.props;
---

<div class="border border-[var(--color-border)] rounded-lg p-6 hover:border-[var(--color-primary)] transition-colors">
  <a href={`/blog/${slug}`} class="no-underline">
    <h2 class="text-xl font-bold mb-2 hover:text-[var(--color-primary)] transition-colors">
      {title}
    </h2>
  </a>
  {
    description && (
      <p class="text-[var(--color-text-secondary)] mb-3 line-clamp-2">{description}</p>
    )
  }
  <div class="flex flex-wrap items-center gap-3 text-xs text-[var(--color-text-secondary)]">
    <time datetime={date}>
      {new Date(date).toLocaleDateString("zh-CN", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })}
    </time>
    {
      tags && tags.length > 0 && (
        <div class="flex gap-1.5">
          {tags.map((tag) => <span>#{tag}</span>)}
        </div>
      )
    }
  </div>
</div>
